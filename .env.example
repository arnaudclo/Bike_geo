# Copier ce fichier en ".env" et adapter le chemin à ton install Fusion 360.
# Ce chemin pointe vers le dossier "Api/Python/packages" de ta version de Fusion 360
# (visible dans %LOCALAPPDATA%/Autodesk/webdeploy/production/<hash>/Api/Python/packages).
PYTHONPATH=C:/Users/<ton_user>/AppData/Local/Autodesk/webdeploy/production/<hash>/Api/Python/packages
